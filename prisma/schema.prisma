generator client {
  provider = "prisma-client-js"

}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User{
  id String @id @default(auto()) @map("_id") @db.ObjectId
  username String @unique
  firstName String
  lastName String
  email String @unique
  password String
  gender Gender
  dob DateTime
  role Role
  phoneNo String?
  country String?
  state String?
  city String?
  address String?
  hobby String?
  profession String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
enum Gender{
  MALE
  FEMALE
  OTHER
}
enum Role{
  USER
  ADMIN
}